{
  "version": 1,
  "canonical": true,
  "description": "Canonical workflow metadata for the repository's single-entry orchestrator. This file defines task classes, workflow phases, context-engineering policy, capability routing, approval categories, and skill triggers. Agent markdown, prompts, and docs should align with this manifest.",
  "artifacts": {
    "repoMap": ".github/agent-platform/repo-map.json",
    "skillRegistry": ".github/agent-platform/skill-registry.json",
    "contextPacketSchema": ".github/agent-platform/context-packet.schema.json",
    "runArtifactSchema": ".github/agent-platform/run-artifact-schema.json"
  },
  "workflow": {
    "phaseOrder": [
      "goal-anchor",
      "classify",
      "breadth-scan",
      "depth-dive",
      "lock-requirements",
      "choose-approach",
      "adversarial-critique",
      "revise",
      "execute-or-answer",
      "traceability-and-verify"
    ],
    "maxCritiquePasses": 2,
    "requireSpecFor": [
      "brownfield-improvement",
      "greenfield-feature",
      "implement-from-existing-spec",
      "workflow-change",
      "architecture-change",
      "ci-change"
    ],
    "specUsuallyOptionalFor": [
      "trivial",
      "research-only",
      "review-only",
      "docs-only"
    ]
  },
  "contextEngineering": {
    "packetSchema": ".github/agent-platform/context-packet.schema.json",
    "goalAnchorPolicy": "Re-inject the one-line top-level goal at the top of every non-trivial LLM call.",
    "memoryTiers": [
      "working",
      "episodic",
      "semantic"
    ],
    "rollingWindow": {
      "recentTurns": 2,
      "episodicCompressionRequired": true,
      "staleToolOutputTtl": "one-subtask"
    },
    "healthGate": {
      "maxContextUtilizationPct": 70,
      "onThresholdExceeded": [
        "trim-stale-tool-output",
        "compress-episode-memory",
        "retain-goal-anchor-active-constraints-and-current-step-only"
      ]
    },
    "subtaskExecution": {
      "requireAtomicContracts": true,
      "maxLlmCallsPerSubtask": 1,
      "splitIfMultiCall": true,
      "routeViaTaskRouter": true,
      "scratchpadScope": "current-subtask-only"
    },
    "ambiguousSubtaskPolicy": {
      "candidateApproachCount": 3,
      "scoreDimensions": [
        "correctness",
        "efficiency",
        "risk"
      ],
      "executeHighestScoreOnly": true
    },
    "structuredReasoning": {
      "toolFamily": "sequential-thinking-optional",
      "allowedTaskClasses": [
        "brownfield-improvement",
        "greenfield-feature",
        "implement-from-existing-spec",
        "test-only",
        "docs-only"
      ],
      "useWhen": [
        "ambiguous-subtask",
        "complex-plan",
        "adversarial-critique",
        "multi-branch-investigation"
      ],
      "requiredOutput": "summary-only",
      "defaultRetention": "context-packet-summary-only",
      "avoidByDefault": [
        "export-session",
        "import-session"
      ],
      "clearHistoryPolicy": "clear-before-reuse-and-after-summary-when-prior-state-is-no-longer-needed",
      "notes": "Sequential Thinking session state is scratch space only and is not durable repo memory or evidence."
    },
    "observability": {
      "taskLedgerField": "taskLedger",
      "requiredMetrics": [
        "taskId",
        "tokensIn",
        "tokensOut",
        "contextSizeKb",
        "contextUtilizationPct",
        "completionStatus"
      ]
    },
    "memoryHydration": {
      "scopes": [
        "repo",
        "session",
        "user"
      ],
      "defaultScopeOrder": [
        "repo",
        "session",
        "user"
      ],
      "loadOnDemandOnly": true,
      "recordLoadedSourcesInPacket": true,
      "notes": "Memory scopes may be editor-managed rather than normal repo files; packet metadata records the source without requiring filesystem validation."
    },
    "runArtifactPolicy": {
      "activateForTaskClasses": [
        "brownfield-improvement",
        "greenfield-feature",
        "implement-from-existing-spec",
        "review-only",
        "research-only",
        "test-only",
        "docs-only"
      ],
      "activateWhen": [
        "multi-surface",
        "multi-subtask",
        "evidence-heavy"
      ],
      "recordTaskLedgerAfterEachSubtask": true,
      "allowInMemoryArtifactWhenNoRepoPath": true
    }
  },
  "taskClasses": {
    "trivial": {
      "summary": "One-line answers, tiny changes, or direct commands with low ambiguity.",
      "defaultCapabilities": [
        "repo-read"
      ]
    },
    "research-only": {
      "summary": "External or internal research with no code changes.",
      "defaultCapabilities": [
        "repo-read",
        "web-research"
      ]
    },
    "review-only": {
      "summary": "Independent adversarial review with findings first.",
      "defaultCapabilities": [
        "repo-read"
      ]
    },
    "brownfield-improvement": {
      "summary": "Changes to existing behavior, code quality, reliability, or workflows.",
      "defaultCapabilities": [
        "repo-read",
        "repo-write-local",
        "structured-reasoning",
        "terminal-exec",
        "browser-e2e"
      ]
    },
    "greenfield-feature": {
      "summary": "New capability or larger new workflow built from explicit requirements.",
      "defaultCapabilities": [
        "repo-read",
        "repo-write-local",
        "structured-reasoning",
        "terminal-exec",
        "browser-e2e",
        "web-research"
      ]
    },
    "implement-from-existing-spec": {
      "summary": "Implementation work driven by an approved active spec.",
      "defaultCapabilities": [
        "repo-read",
        "repo-write-local",
        "structured-reasoning",
        "terminal-exec",
        "browser-e2e"
      ]
    },
    "test-only": {
      "summary": "Focused test generation or hardening pass.",
      "defaultCapabilities": [
        "repo-read",
        "repo-write-local",
        "structured-reasoning",
        "terminal-exec",
        "browser-e2e"
      ]
    },
    "docs-only": {
      "summary": "Contributor or architecture documentation updates with no product behavior change.",
      "defaultCapabilities": [
        "repo-read",
        "repo-write-local",
        "structured-reasoning"
      ]
    }
  },
  "capabilities": {
    "repo-read": {
      "description": "Read repository files, branches, commits, and metadata.",
      "toolFamilies": [
        "filesystem-read",
        "github-read"
      ]
    },
    "repo-write-local": {
      "description": "Create or edit local repository files.",
      "toolFamilies": [
        "filesystem-write"
      ],
      "approval": "ask-on-sensitive-paths"
    },
    "repo-write-remote": {
      "description": "Mutate remote repository state such as files, pull requests, issues, comments, or workflow runs.",
      "toolFamilies": [
        "github-write"
      ],
      "approval": "always-ask"
    },
    "web-research": {
      "description": "Fetch external documentation or broader web search when available and configured.",
      "toolFamilies": [
        "fetch",
        "tavily-optional"
      ]
    },
    "structured-reasoning": {
      "description": "Use Sequential Thinking as a bounded reasoning aid for ambiguous planning, critique, or multi-branch investigations.",
      "toolFamilies": [
        "sequential-thinking-optional"
      ]
    },
    "browser-e2e": {
      "description": "Browser automation, screenshots, traces, and UI verification when an editor/browser tool is available.",
      "toolFamilies": [
        "playwright-optional",
        "browser-tools-optional"
      ]
    },
    "terminal-exec": {
      "description": "Run local verification commands and targeted scripts.",
      "toolFamilies": [
        "terminal"
      ],
      "approval": "allow-read-default-ask-high-risk"
    }
  },
  "approval": {
    "sensitivePaths": [
      ".github/hooks/",
      ".github/workflows/",
      ".github/agent-platform/",
      "scripts/agent/",
      ".vscode/settings.json",
      ".vscode/mcp.json",
      ".github/copilot-instructions.md",
      ".env"
    ],
    "terminalAskCategories": [
      "network-fetch",
      "dependency-mutation",
      "remote-push",
      "workflow-dispatch",
      "destructive-cleanup"
    ],
    "remoteWriteAlwaysAsk": true
  },
  "skills": {
    "feature-discovery": {
      "path": ".github/skills/feature-discovery/SKILL.md",
      "triggers": [
        "vague-request",
        "greenfield-discovery"
      ]
    },
    "spec-validation": {
      "path": ".github/skills/spec-validation/SKILL.md",
      "triggers": [
        "spec-created",
        "spec-updated"
      ]
    },
    "adversarial-review": {
      "path": ".github/skills/adversarial-review/SKILL.md",
      "triggers": [
        "non-trivial",
        "medium-risk",
        "high-risk"
      ]
    },
    "requirements-traceability": {
      "path": ".github/skills/requirements-traceability/SKILL.md",
      "triggers": [
        "non-trivial"
      ]
    },
    "test-hardening": {
      "path": ".github/skills/test-hardening/SKILL.md",
      "triggers": [
        "brownfield",
        "bugfix",
        "regression-sensitive"
      ]
    },
    "regression-audit": {
      "path": ".github/skills/regression-audit/SKILL.md",
      "triggers": [
        "brownfield",
        "bugfix",
        "refactor"
      ]
    },
    "debug-timeline-capture": {
      "path": ".github/skills/debug-timeline-capture/SKILL.md",
      "triggers": [
        "bugfix",
        "flaky-test",
        "launch-blocker",
        "ui-repro"
      ]
    },
    "frontend-best-practices": {
      "path": ".github/skills/frontend-best-practices/SKILL.md",
      "triggers": [
        "frontend",
        "react",
        "user-facing-ui"
      ]
    },
    "visual-qa": {
      "path": ".github/skills/visual-qa/SKILL.md",
      "triggers": [
        "frontend",
        "user-facing-ui",
        "visual-change"
      ]
    },
    "observability-inject": {
      "path": ".github/skills/observability-inject/SKILL.md",
      "triggers": [
        "api",
        "auth",
        "storage",
        "execution",
        "runtime"
      ]
    },
    "documentation-audit": {
      "path": ".github/skills/documentation-audit/SKILL.md",
      "triggers": [
        "workflow-change",
        "architecture-change",
        "prompt-change",
        "skill-change",
        "ci-change",
        "docs-change"
      ]
    },
    "sequential-thinking-guardrails": {
      "path": ".github/skills/sequential-thinking-guardrails/SKILL.md",
      "triggers": [
        "ambiguous-subtask",
        "complex-plan",
        "adversarial-critique",
        "multi-branch-investigation",
        "structured-reasoning"
      ]
    },
    "continuous-audit": {
      "path": ".github/skills/continuous-audit/SKILL.md",
      "triggers": [
        "release-sensitive",
        "repo-health-audit"
      ]
    },
    "adr": {
      "path": ".github/skills/adr/SKILL.md",
      "triggers": [
        "architectural-decision"
      ]
    }
  },
  "triggerMatrix": [
    {
      "when": [
        "any-non-trivial-task"
      ],
      "apply": [
        "adversarial-review",
        "requirements-traceability"
      ]
    },
    {
      "when": [
        "spec-created-or-refreshed"
      ],
      "apply": [
        "spec-validation"
      ]
    },
    {
      "when": [
        "brownfield",
        "bugfix",
        "regression-sensitive"
      ],
      "apply": [
        "test-hardening",
        "regression-audit",
        "debug-timeline-capture"
      ]
    },
    {
      "when": [
        "frontend",
        "user-facing-ui"
      ],
      "apply": [
        "frontend-best-practices",
        "visual-qa"
      ],
      "notes": [
        "Accessibility review remains explicit and is not replaced by frontend-best-practices."
      ]
    },
    {
      "when": [
        "api",
        "auth",
        "storage",
        "execution",
        "runtime"
      ],
      "apply": [
        "observability-inject"
      ]
    },
    {
      "when": [
        "workflow",
        "architecture",
        "ci",
        "prompt",
        "skill",
        "docs"
      ],
      "apply": [
        "documentation-audit"
      ]
    },
    {
      "when": [
        "ambiguous-subtask",
        "complex-plan",
        "adversarial-critique",
        "multi-branch-investigation",
        "structured-reasoning"
      ],
      "apply": [
        "sequential-thinking-guardrails"
      ],
      "notes": [
        "Retain only summary-level conclusions in the context packet or run artifact and avoid routine import/export use."
      ]
    },
    {
      "when": [
        "release-sensitive",
        "repo-health-audit"
      ],
      "apply": [
        "continuous-audit"
      ]
    },
    {
      "when": [
        "external-context"
      ],
      "apply": [
        "research-first"
      ],
      "artifacts": [
        "docs/specs/research/<slug>-research.md"
      ]
    }
  ]
}