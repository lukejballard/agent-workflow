{
  "version": 1,
  "canonical": true,
  "description": "Workflow policy kernel for the single hyperintelligent orchestrator. Defines task classes, phase order, requirement locking, memory discipline, retry policy, and verification semantics.",
  "workflow": {
    "phaseOrder": [
      "goal-anchor",
      "classify",
      "breadth-scan",
      "depth-dive",
      "lock-requirements",
      "choose-approach",
      "adversarial-critique",
      "revise",
      "execute-or-answer",
      "self-review",
      "critique",
      "traceability-and-verify"
    ],
    "maxCritiquePasses": 2,
    "maxAttemptsPerSubtask": 2,
    "requireExplicitRequirementsFor": [
      "brownfield-improvement",
      "greenfield-feature",
      "implement-from-existing-spec"
    ],
    "explicitRequirementLockOptionalFor": [
      "trivial",
      "research-only",
      "review-only",
      "docs-only"
    ]
  },
  "implementationDefaults": {
    "description": "Default application stack for generated work when the user and host repo do not already establish a different implementation path.",
    "overridePrecedence": [
      "explicit-user-request",
      "host-repo-established-stack",
      "package-default"
    ],
    "applyWhenTaskClasses": [
      "greenfield-feature",
      "implement-from-existing-spec",
      "brownfield-improvement"
    ],
    "respectEstablishedRepoStack": true,
    "packageDefault": {
      "backend": {
        "language": "python",
        "framework": "fastapi",
        "validation": "pydantic-v2",
        "orm": "sqlalchemy-2",
        "migrations": "alembic"
      },
      "frontend": {
        "language": "typescript",
        "framework": "react",
        "build": "vite",
        "testing": "vitest",
        "componentTesting": "react-testing-library",
        "routing": "react-router-dom"
      }
    }
  },
  "requirementLock": {
    "preferredSources": [
      "repo-spec-or-plan",
      "issue-or-ticket",
      "inline-requirements-contract"
    ],
    "requiredFields": [
      "problem",
      "behaviors",
      "constraints",
      "verification"
    ]
  },
  "memoryPolicy": {
    "workingMemoryScope": "current-step-only",
    "episodicCompression": "required-after-completed-step",
    "durableMemory": {
      "requireProvenance": true,
      "preferFreshEvidence": true,
      "ignoreStaleOrUnverified": true
    },
    "failureKnowledge": {
      "store": ".github/hooks/failures/",
      "writer": ".github/hooks/failure_index.py",
      "queryAtBootstrap": true
    },
    "decisionKnowledge": {
      "store": "docs/specs/research/",
      "writePolicy": "researchBriefPolicy"
    }
  },
  "recoveryPolicy": {
    "classifyFailuresAs": [
      "transient-tool",
      "transient-environment",
      "missing-context",
      "requirements-gap",
      "unsafe-block",
      "logic-defect"
    ],
    "retryOnlyWhenStrategyChanges": true,
    "neverRepeatIdenticalStep": true,
    "escalateAfterAttempts": 2
  },
  "verificationPolicy": {
    "requireVerificationMatrixFor": [
      "brownfield-improvement",
      "greenfield-feature",
      "implement-from-existing-spec",
      "test-only"
    ],
    "requireEvidencePerClaim": true,
    "allowedFinalStates": [
      "verified",
      "partially-verified",
      "blocked"
    ],
    "confidenceSignals": [
      "evidence-density",
      "verification-depth",
      "memory-freshness"
    ]
  },
  "taskClasses": [
    "trivial",
    "research-only",
    "review-only",
    "brownfield-improvement",
    "greenfield-feature",
    "implement-from-existing-spec",
    "test-only",
    "docs-only"
  ],
  "phaseSkipRules": {
    "trivial": {
      "skip": ["lock-requirements", "adversarial-critique", "revise", "self-review", "critique"],
      "reason": "Trivial tasks don't need requirement contracts or critique cycles."
    },
    "research-only": {
      "skip": ["lock-requirements", "choose-approach", "adversarial-critique", "revise", "execute-or-answer", "self-review", "critique"],
      "reason": "Research tasks collect and surface information; they don't implement."
    },
    "review-only": {
      "skip": ["lock-requirements", "adversarial-critique", "revise", "execute-or-answer"],
      "reason": "Review tasks analyze existing code; they produce findings, not implementations."
    },
    "docs-only": {
      "skip": ["adversarial-critique", "revise", "self-review", "critique"],
      "reason": "Documentation changes need breadth scan and requirement awareness but not a full critique cycle."
    },
    "test-only": {
      "skip": ["adversarial-critique", "self-review"],
      "reason": "Test-only tasks follow the spec; critique the implementation under test, not the tests themselves."
    }
  },
  "auditPolicy": {
    "description": "Recurring adversarial self-audit cadence and triggers.",
    "triggers": {
      "onDemand": "@orchestrator audit",
      "everyNClosedNonTrivialTasksPerSurface": 10,
      "onAnyBlockedFinalState": true
    },
    "charterDocument": "docs/runbooks/adversarial-audit.md",
    "outputArtifactDirectory": "docs/specs/research/",
    "outputSlugPattern": "audit-<surface>-<YYYYMMDD>.md",
    "minimumDimensionsScored": 12,
    "capabilityClassification": ["fully-real", "partially-real", "illusory"],
    "missingEnforcementImpliesIllusory": true,
    "stateFlags": [
      "audit_due",
      "audit_due_reason",
      "last_blocked_at",
      "closed_task_count_per_surface",
      "last_audit_at_per_surface"
    ]
  },
  "researchBriefPolicy": {
    "description": "When the orchestrator must compile durable decision knowledge in docs/specs/research/. Complementary to failure_index, which captures failure knowledge.",
    "requiredWhen": [
      "external-source-changed-non-trivial-plan",
      "conflicting-sources-resolved",
      "framework-or-stack-decision-required-evidence",
      "audit-mode-output"
    ],
    "schemaDocument": "docs/specs/research/README.md",
    "linkRequirementFromSpecsThatDependOnIt": true
  },
  "frontendQualityTargets": {
    "description": "Hard, machine-checkable thresholds for elite-tier frontend deliverables. Authoritative numbers live in performance.instructions.md.",
    "coreWebVitalsRef": ".github/instructions/performance.instructions.md",
    "bundleDeltaPerNewPage_kBGzipped": 20,
    "minTestCoverageLineAndBranchPercent": 80,
    "wcagLevel": "2.2-AA",
    "asyncStatesRequired": ["idle", "loading", "success", "empty", "error"]
  }
}