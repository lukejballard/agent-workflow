{
  "version": 1,
  "description": "Deterministic workflow-contract benchmarks for prompt wrappers. These checks validate prompt entrypoint contracts, not end-to-end model quality.",
  "benchmarks": [
    {
      "id": "single-entry-workflow",
      "path": ".github/prompts/single-entry-workflow.prompt.md",
      "agent": "orchestrator",
      "tools": [
        "read",
        "search",
        "edit",
        "execute",
        "browser",
        "sequential-thinking/*",
        "github/*",
        "fetch/*"
      ],
      "required_markers": [
        "# Single-Entry Workflow",
        "<goal>{{task}}</goal>",
        "<constraints>{{constraints}}</constraints>",
        "<done_when>{{done_when}}</done_when>",
        "<current_step id=\"classify-and-route\">"
      ]
    },
    {
      "id": "greenfield-feature",
      "path": ".github/prompts/greenfield-feature.prompt.md",
      "agent": "orchestrator",
      "tools": [
        "read",
