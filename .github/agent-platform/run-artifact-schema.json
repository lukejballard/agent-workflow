{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Run Artifact",
  "description": "Lightweight optional run artifact for longer investigations or cross-surface changes. This schema is repo-local traceability metadata, not a durable runtime session format. It can also capture per-subtask context telemetry for longer workflows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskClass",
    "objective",
    "status",
    "summary",
    "touchedPaths",
    "verification",
    "residualRisks"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "taskClass": {
      "type": "string",
      "enum": [
        "trivial",
        "research-only",
        "review-only",
        "brownfield-improvement",
        "greenfield-feature",
        "implement-from-existing-spec",
        "test-only",
        "docs-only"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "linkedSpec": {
      "type": "string",
      "pattern": "^(docs/specs/(active|done)/[A-Za-z0-9._/-]+\\.md|\\[no-spec\\])$"
    },
    "linkedResearch": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^docs/specs/research/[A-Za-z0-9._/-]+\\.md$"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": [
        "in-progress",
        "blocked",
        "review-needed",
        "done"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "touchedPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "summary",
          "source"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "timestampUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "taskLedger": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskId",
          "completionStatus"
        ],
        "properties": {
          "taskId": {
            "type": "string",
            "minLength": 1
          },
          "route": {
            "type": "string",
            "minLength": 1
          },
          "tokensIn": {
            "type": "integer",
            "minimum": 0
          },
          "tokensOut": {
            "type": "integer",
            "minimum": 0
          },
          "contextSizeKb": {
            "type": "number",
            "minimum": 0
          },
          "contextUtilizationPct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "completionStatus": {
            "type": "string",
            "enum": [
              "done",
              "blocked",
              "failed",
              "skipped",
              "in-progress"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "status",
          "details"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "passed",
              "failed",
              "not-run",
              "advisory"
            ]
          },
          "details": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "minItems": 1
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
