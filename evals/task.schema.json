{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvalTask",
  "description": "A single benchmark task for the orchestrator eval harness.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "taskClass", "prompt", "rubric", "tags"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique kebab-case task identifier."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "taskClass": {
      "type": "string",
      "enum": [
        "trivial",
        "research-only",
        "review-only",
        "brownfield-improvement",
        "greenfield-feature",
        "implement-from-existing-spec",
        "test-only",
        "docs-only"
      ]
    },
    "prompt": {
      "type": "string",
      "minLength": 10,
      "description": "The user prompt fed to the orchestrator."
    },
    "expectedProperties": {
      "type": "object",
      "description": "Optional free-form key/value expectations for the orchestrator response.",
      "additionalProperties": {
        "type": ["string", "boolean", "number"]
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification"],
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["required", "advisory", "skip"],
          "description": "Whether the orchestrator must correctly classify into taskClass."
        },
        "phase_coverage": {
          "type": "string",
          "enum": ["required", "advisory", "skip"],
          "description": "Whether the expected workflow phases must be reached."
        },
        "spec_created": {
          "type": "string",
          "enum": ["required", "forbidden", "advisory", "skip"],
          "description": "Whether a spec file must be created before code."
        },
        "skill_triggered": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Skills that must be loaded for this task to pass."
        },
        "adversarial_triggered": {
          "type": "string",
          "enum": ["required", "forbidden", "advisory", "skip"],
          "description": "Whether Phase 6 adversarial critique must be invoked."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1,
      "uniqueItems": true
    },
    "notes": {
      "type": "string"
    }
  }
}
